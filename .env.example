# Vortex / Remicle Configuration — example
# Copy to .env and fill in real values for your environment.

# ─── Database ────────────────────────────────────────────────────────
# The server runs as this role. Migrations should be run by a role with
# CREATEROLE so the `vortex_runtime` role can be created automatically
# (see migrations/114_audit_worm/postgres.sql). For production, split:
#   - run `vortex db migrate` as the DB owner
#   - start `vortex server` using DATABASE_URL pointing at vortex_runtime
DATABASE_URL=postgres://vortex_runtime:CHANGE_ME@localhost/vortex

# ─── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000

# ─── Session / Auth ──────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_32+_bytes_of_entropy
SESSION_TIMEOUT_MINUTES=30

# ─── WORM Audit Ledger (CIP-007-6 R5 / CIP-010-4 R1) ─────────────────
# Ed25519 private key used to sign every audit chain entry. Generate once,
# store in your secrets manager, inject at deploy time:
#
#   openssl genpkey -algorithm ed25519 -outform DER | base64 -w0
#
# The public half is automatically upserted into `audit_signing_keys` on
# first server startup so `vortex audit verify` can validate historical
# entries even after key rotation.
VORTEX_AUDIT_SIGNING_KEY=
VORTEX_AUDIT_SIGNING_KEY_ID=default

# Set to `disabled` to skip signing entirely (hash chain remains). Only
# acceptable for local development; production MUST leave this unset.
# VORTEX_AUDIT_SIGNING_MODE=disabled

# ─── Logging ─────────────────────────────────────────────────────────
RUST_LOG=info,vortex=debug

# ─── Master encryption key (REQUIRED in production) ──────────────────
# Seals secrets at rest (SMTP passwords, integration API keys, TOTP
# seeds) with AES-256-GCM, and signs the MFA pre-auth token. Base64 of
# exactly 32 random bytes:
#
#   openssl rand -base64 32
#
# The server REFUSES TO START without it. Rotating it makes previously
# sealed values undecryptable — stored credentials must be re-entered
# and MFA re-enrolled — so set it once, before go-live, and keep it in
# the deployment's secret store.
VORTEX_SECRET_KEY=

# Local development escape hatch: run on the insecure built-in key that
# is published in the Vortex source. Never set this in production.
# VORTEX_ALLOW_DEV_KEY=1

# ─── Transport security ──────────────────────────────────────────────
# HSTS is emitted only on requests that arrived over TLS (the proxy
# forwards X-Forwarded-Proto: https, or VORTEX_SECURE_COOKIES forces
# it). Override the value here, or set `off` to suppress it where a
# sibling host on the parent domain is not yet HTTPS-only.
# VORTEX_HSTS=max-age=31536000; includeSubDomains
