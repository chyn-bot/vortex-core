-- __DISPLAY__ — initial schema.
--
-- One example record type ("item"). Rename/extend to your domain.
-- The model is registered in `ir_model` / `ir_model_field`
-- automatically from `#[derive(Model)]` (see `src/model.rs` and
-- `Plugin::models()`) — that is what makes it visible to the list
-- framework, the report builder, and the public REST API. Keep this
-- table's columns in sync with the struct; do NOT hand-seed the
-- registry here.

CREATE TABLE IF NOT EXISTS __SNAKE___item (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    -- stamped from the sequence right after insert (nullable so the
    -- form engine's INSERT doesn't need to know about it)
    code VARCHAR(32) UNIQUE,
    name VARCHAR(255) NOT NULL,
    description TEXT,
    record_state VARCHAR(32) NOT NULL DEFAULT 'draft',
    active BOOLEAN NOT NULL DEFAULT true,
    created_by UUID REFERENCES users(id),
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx___SNAKE___item_state ON __SNAKE___item(record_state);

